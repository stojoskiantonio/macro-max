<?xml version="1.0" encoding="utf-8"?>
<!-- Tablet (≥600dp): permanent two-column layout with larger visual elements -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Two-column content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingBottom="64dp">

        <!-- ── LEFT COLUMN: macro card + activity ring + water ─────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainScrollView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="10dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <!-- Greeting row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingEnd="56dp"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="Summary" />

                        <TextView
                            android:id="@+id/tvTodayDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:alpha="0.45"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="Saturday, 23 May" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Macro card (tablet: larger donut) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMacros"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <com.example.macromax.MacroDonutView
                            android:id="@+id/macroDonut"
                            android:layout_width="120dp"
                            android:layout_height="120dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="20dp">

                            <!-- Protein -->
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="3dp">
                                <View android:layout_width="5dp" android:layout_height="5dp" android:background="#4CAF50" android:layout_marginEnd="8dp" />
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/result_protein" android:textSize="12sp" android:alpha="0.5" />
                                <TextView android:id="@+id/tvProteinVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" tools:text="0g / 187g" />
                            </LinearLayout>
                            <ProgressBar android:id="@+id/pbProtein" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="10dp" android:max="100" android:progressTint="#4CAF50" android:progressBackgroundTint="#1A4CAF50" />

                            <!-- Fat -->
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="3dp">
                                <View android:layout_width="5dp" android:layout_height="5dp" android:background="#EF5350" android:layout_marginEnd="8dp" />
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/result_fat" android:textSize="12sp" android:alpha="0.5" />
                                <TextView android:id="@+id/tvFatVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" tools:text="0g / 75g" />
                            </LinearLayout>
                            <ProgressBar android:id="@+id/pbFat" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="10dp" android:max="100" android:progressTint="#EF5350" android:progressBackgroundTint="#1AEF5350" />

                            <!-- Carbs -->
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="3dp">
                                <View android:layout_width="5dp" android:layout_height="5dp" android:background="#64B5F6" android:layout_marginEnd="8dp" />
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/result_carbs" android:textSize="12sp" android:alpha="0.5" />
                                <TextView android:id="@+id/tvCarbsVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" tools:text="0g / 315g" />
                            </LinearLayout>
                            <ProgressBar android:id="@+id/pbCarbs" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="3dp" android:max="100" android:progressTint="#64B5F6" android:progressBackgroundTint="#1A64B5F6" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Net calories row -->
                    <LinearLayout
                        android:id="@+id/rowNetCalories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_line" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="10dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Net" android:textSize="12sp" android:alpha="0.45" android:layout_marginEnd="12dp" />
                            <TextView android:id="@+id/tvNetCalories" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="18sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" tools:text="1,450 kcal" />
                            <TextView android:id="@+id/tvNetBreakdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:alpha="0.45" tools:text="2,100 eaten − 650 burned" />

                        </LinearLayout>
                    </LinearLayout>

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnAddFoodFromCard"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp"
                        android:padding="7dp"
                        android:src="@drawable/ic_add"
                        android:alpha="0.5"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/log_food_title" />

                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Activity ring card (tablet: larger ring) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardActivityRing"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/main_activity_ring"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:alpha="0.6"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginBottom="10dp" />

                            <com.example.macromax.ActivityRingView
                                android:id="@+id/activityRing"
                                android:layout_width="100dp"
                                android:layout_height="100dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="24dp"
                            android:gravity="center_vertical">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/main_move_label" android:textSize="13sp" android:alpha="0.5" android:textColor="?attr/colorOnSurface" />

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom" android:layout_marginTop="4dp">
                                <TextView android:id="@+id/tvActivityKcal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="34sp" android:textStyle="bold" android:textColor="#F44336" tools:text="0" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="/" android:textSize="20sp" android:textStyle="bold" android:textColor="#F44336" android:alpha="0.5" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="3dp" />
                                <TextView android:id="@+id/tvActivityKcalGoal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="20sp" android:textStyle="bold" android:textColor="#F44336" android:alpha="0.65" android:layout_marginBottom="3dp" tools:text="400" />
                            </LinearLayout>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KCAL" android:textSize="11sp" android:textStyle="bold" android:textColor="#F44336" android:alpha="0.65" />

                        </LinearLayout>

                    </LinearLayout>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_gravity="top|end" android:layout_margin="12dp" android:src="@drawable/ic_chevron_right" android:alpha="0.25" android:contentDescription="Details" />

                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Water card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWater"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="18dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/water_title" android:textSize="14sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                            <TextView android:id="@+id/tvWaterCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" android:textColor="#64B5F6" tools:text="750 ml / 2000 ml" />
                        </LinearLayout>

                        <com.example.macromax.WaterDropsView android:id="@+id/waterDropsView" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginBottom="14dp" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <com.google.android.material.button.MaterialButton android:id="@+id/btnWaterMinus" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="44dp" android:layout_height="44dp" android:text="−" android:textSize="20sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" app:cornerRadius="22dp" />
                            <TextView android:id="@+id/tvWaterGlasses" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textSize="13sp" android:alpha="0.5" tools:text="3 of 8 glasses" />
                            <com.google.android.material.button.MaterialButton android:id="@+id/btnWaterPlus" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="44dp" android:layout_height="44dp" android:text="+" android:textSize="20sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" app:cornerRadius="22dp" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── RIGHT COLUMN: steps + workouts + meal breakdown + food ─── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <!-- Spacer to align with greeting text height in left col -->
                <Space android:layout_width="match_parent" android:layout_height="56dp" />

                <!-- Step count + distance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStepCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="12dp" android:paddingTop="14dp" android:paddingBottom="10dp">

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/main_step_count" android:textSize="13sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:alpha="0.35" android:contentDescription="@null" />
                            </LinearLayout>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/main_today_label" android:textSize="12sp" android:alpha="0.5" android:layout_marginTop="3dp" />
                            <TextView android:id="@+id/tvStepCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="32sp" android:textStyle="bold" android:textColor="#CE93D8" android:layout_marginTop="2dp" tools:text="0" />
                            <com.example.macromax.HourlyBarChartView android:id="@+id/stepBarChart" android:layout_width="match_parent" android:layout_height="64dp" android:layout_marginTop="8dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <Space android:layout_width="12dp" android:layout_height="match_parent" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStepDistance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="12dp" android:paddingTop="14dp" android:paddingBottom="10dp">

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/main_step_distance" android:textSize="13sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:alpha="0.35" android:contentDescription="@null" />
                            </LinearLayout>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/main_today_label" android:textSize="12sp" android:alpha="0.5" android:layout_marginTop="3dp" />
                            <TextView android:id="@+id/tvStepDistance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="32sp" android:textStyle="bold" android:textColor="#4DD0E1" android:layout_marginTop="2dp" tools:text="0.00 KM" />
                            <com.example.macromax.HourlyBarChartView android:id="@+id/distanceBarChart" android:layout_width="match_parent" android:layout_height="64dp" android:layout_marginTop="8dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Workouts card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWorkouts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="18dp" android:paddingTop="14dp" android:paddingBottom="6dp">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/workout_section_title" android:textSize="14sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                            <com.google.android.material.button.MaterialButton android:id="@+id/btnLogWorkout" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="36dp" android:text="@string/workout_log_btn" android:textSize="13sp" android:insetTop="0dp" android:insetBottom="0dp" />
                        </LinearLayout>

                        <TextView android:id="@+id/tvWorkoutsEmpty" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/workout_empty" android:textSize="13sp" android:alpha="0.4" android:gravity="center" android:paddingVertical="10dp" />
                        <LinearLayout android:id="@+id/containerWorkouts" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Meal Breakdown card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMealBreakdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="14dp" android:paddingTop="14dp" android:paddingBottom="12dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/meal_breakdown_title" android:textSize="13sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" android:layout_marginBottom="12dp" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:paddingHorizontal="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/meal_short_breakfast" android:textSize="11sp" android:alpha="0.5" android:layout_marginBottom="3dp" />
                                <TextView android:id="@+id/tvMealBfastKcal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorPrimary" android:text="0" />
                                <ProgressBar android:id="@+id/pbMealBfast" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="5dp" android:layout_marginBottom="4dp" android:max="100" android:progressTint="?attr/colorPrimary" android:progressBackgroundTint="?attr/colorSurfaceVariant" />
                                <TextView android:id="@+id/tvMealBfastOf" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="10sp" android:alpha="0.45" android:text="—" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:paddingHorizontal="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/meal_short_lunch" android:textSize="11sp" android:alpha="0.5" android:layout_marginBottom="3dp" />
                                <TextView android:id="@+id/tvMealLunchKcal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorPrimary" android:text="0" />
                                <ProgressBar android:id="@+id/pbMealLunch" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="5dp" android:layout_marginBottom="4dp" android:max="100" android:progressTint="?attr/colorPrimary" android:progressBackgroundTint="?attr/colorSurfaceVariant" />
                                <TextView android:id="@+id/tvMealLunchOf" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="10sp" android:alpha="0.45" android:text="—" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:paddingHorizontal="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/meal_short_dinner" android:textSize="11sp" android:alpha="0.5" android:layout_marginBottom="3dp" />
                                <TextView android:id="@+id/tvMealDinnerKcal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorPrimary" android:text="0" />
                                <ProgressBar android:id="@+id/pbMealDinner" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="5dp" android:layout_marginBottom="4dp" android:max="100" android:progressTint="?attr/colorPrimary" android:progressBackgroundTint="?attr/colorSurfaceVariant" />
                                <TextView android:id="@+id/tvMealDinnerOf" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="10sp" android:alpha="0.45" android:text="—" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:paddingHorizontal="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/meal_short_snack" android:textSize="11sp" android:alpha="0.5" android:layout_marginBottom="3dp" />
                                <TextView android:id="@+id/tvMealSnackKcal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorPrimary" android:text="0" />
                                <ProgressBar android:id="@+id/pbMealSnack" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="5dp" android:layout_marginBottom="4dp" android:max="100" android:progressTint="?attr/colorPrimary" android:progressBackgroundTint="?attr/colorSurfaceVariant" />
                                <TextView android:id="@+id/tvMealSnackOf" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="10sp" android:alpha="0.45" android:text="—" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Today's food header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="6dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/main_todays_food" android:textSize="14sp" android:textStyle="bold" android:alpha="0.6" android:textColor="?attr/colorOnSurface" />
                    <TextView android:id="@+id/tvTotalConsumed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:alpha="0.5" tools:text="0 kcal" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvNoFood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/main_no_food_logged"
                    android:textSize="14sp"
                    android:alpha="0.45"
                    android:gravity="center"
                    android:paddingVertical="28dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFoodLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    tools:listitem="@layout/item_food_log" />

                <Space android:layout_width="match_parent" android:layout_height="80dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Top scroll shadow -->
    <View
        android:id="@+id/topScrollShadow"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="@drawable/top_scroll_shadow"
        android:alpha="0"
        android:clickable="false"
        android:focusable="false" />

    <include layout="@layout/include_bottom_nav" />

    <!-- Fixed profile chip — top-right -->
    <LinearLayout
        android:id="@+id/layoutProfileChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout android:layout_width="52dp" android:layout_height="52dp">

            <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/profile_double_ring" />
            <View android:layout_width="44dp" android:layout_height="44dp" android:layout_gravity="center" android:background="@drawable/profile_inner_ring" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfilePic"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_person"
                android:tint="#888888"
                app:shapeAppearanceOverlay="@style/CircleImageView" />

        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
