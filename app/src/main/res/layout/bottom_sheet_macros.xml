<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/divider_line"
        android:backgroundTint="?attr/colorOnSurface" />

    <!-- Title -->
    <TextView
        android:id="@+id/bsMacroTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today's Nutrition"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="20dp" />

    <!-- Calories row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Calories"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/bsCaloriesConsumed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/bsCaloriesTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:alpha="0.45"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/bsPbCalories"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginBottom="4dp"
        android:max="100"
        android:progressTint="?attr/colorPrimary"
        android:progressBackgroundTint="?attr/colorSurfaceVariant" />

    <TextView
        android:id="@+id/bsCaloriesRemaining"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:alpha="0.45"
        android:gravity="end"
        android:layout_marginBottom="20dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_line"
        android:layout_marginBottom="16dp" />

    <!-- Protein -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <View
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:background="#4CAF50"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/result_protein"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/bsProteinGrams"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bsProteinKcal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:alpha="0.45"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/bsPbProtein"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginBottom="14dp"
        android:max="100"
        android:progressTint="#4CAF50"
        android:progressBackgroundTint="#334CAF50" />

    <!-- Fat -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <View
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:background="#EF5350"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/result_fat"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/bsFatGrams"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bsFatKcal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:alpha="0.45"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/bsPbFat"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginBottom="14dp"
        android:max="100"
        android:progressTint="#EF5350"
        android:progressBackgroundTint="#33EF5350" />

    <!-- Carbs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <View
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:background="#64B5F6"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/result_carbs"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/bsCarbsGrams"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bsCarbsKcal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:alpha="0.45"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/bsPbCarbs"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginBottom="16dp"
        android:max="100"
        android:progressTint="#64B5F6"
        android:progressBackgroundTint="#3364B5F6" />

    <!-- Burned / Net footer (shown when there's activity data) -->
    <LinearLayout
        android:id="@+id/bsNetRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_line"
            android:layout_marginBottom="14dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bsNetDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_line"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Burned"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/bsBurned"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#EF5350" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Net calories"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/bsNet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
