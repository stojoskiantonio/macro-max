<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="56dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp">

            <!-- Settings button row -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end"
                    android:src="@drawable/ic_settings"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Settings" />
            </FrameLayout>

            <!-- Macro overview card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMacros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="20dp">

                    <com.example.macromax.MacroDonutView
                        android:id="@+id/macroDonut"
                        android:layout_width="110dp"
                        android:layout_height="110dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/main_daily_targets"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginBottom="10dp" />

                        <!-- Protein row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="10dp"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textSize="8sp"
                                android:textColor="#4CAF50" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/result_protein"
                                android:textSize="11sp"
                                android:alpha="0.55"
                                android:layout_marginStart="5dp" />

                            <TextView
                                android:id="@+id/tvProteinVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="160g / 240g" />
                        </LinearLayout>

                        <!-- Fat row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="10dp"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textSize="8sp"
                                android:textColor="#EF5350" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/result_fat"
                                android:textSize="11sp"
                                android:alpha="0.55"
                                android:layout_marginStart="5dp" />

                            <TextView
                                android:id="@+id/tvFatVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="55g / 70g" />
                        </LinearLayout>

                        <!-- Carbs row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="10dp"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textSize="8sp"
                                android:textColor="#64B5F6" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/result_carbs"
                                android:textSize="11sp"
                                android:alpha="0.55"
                                android:layout_marginStart="5dp" />

                            <TextView
                                android:id="@+id/tvCarbsVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="180g / 220g" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step / Activity card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="56dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="20dp">

                    <com.example.macromax.StepDonutView
                        android:id="@+id/stepDonut"
                        android:layout_width="110dp"
                        android:layout_height="110dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/main_activity_section"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginBottom="10dp" />

                        <!-- Steps row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="10dp"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textSize="8sp"
                                android:textColor="#FF9800" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/main_steps_label"
                                android:textSize="11sp"
                                android:alpha="0.55"
                                android:layout_marginStart="5dp" />

                            <TextView
                                android:id="@+id/tvStepCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                tools:text="0" />
                        </LinearLayout>

                        <!-- Calories burned row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="10dp"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textSize="8sp"
                                android:textColor="#FF9800" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/main_calories_burned_label"
                                android:textSize="11sp"
                                android:alpha="0.55"
                                android:layout_marginStart="5dp" />

                            <TextView
                                android:id="@+id/tvCaloriesBurned"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                tools:text="0 kcal" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Today's Food section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="8dp"
                android:paddingHorizontal="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_todays_food"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tvTotalConsumed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:alpha="0.6"
                    tools:text="0 kcal" />
            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvNoFood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_no_food_logged"
                android:textSize="13sp"
                android:alpha="0.45"
                android:gravity="center"
                android:paddingVertical="24dp"
                android:visibility="visible" />

            <!-- Food log list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFoodLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:listitem="@layout/item_food_log" />

            <!-- Bottom spacer so FAB doesn't cover last item -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="88dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB — sits above the bottom nav bar -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="76dp"
        android:src="@drawable/ic_add"
        android:contentDescription="@string/log_food_title" />

    <!-- Bottom navigation bar — plain icon strip, no Material indicator -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="?attr/colorSurface"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_home" />

        <ImageButton
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_history"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu_history" />

        <ImageButton
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_person"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_profile" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
