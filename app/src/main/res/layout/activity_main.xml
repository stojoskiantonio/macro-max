<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="56dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- Greeting + streak row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="Good morning!" />

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="🔥 5 day streak" />

            </LinearLayout>

            <!-- Macro overview card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMacros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="18dp">

                    <com.example.macromax.MacroDonutView
                        android:id="@+id/macroDonut"
                        android:layout_width="110dp"
                        android:layout_height="110dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <!-- Protein row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/result_protein"
                                android:textSize="11sp"
                                android:alpha="0.55" />

                            <TextView
                                android:id="@+id/tvProteinVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="160g / 240g" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbProtein"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginBottom="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#4CAF50"
                            android:progressBackgroundTint="#334CAF50" />

                        <!-- Fat row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/result_fat"
                                android:textSize="11sp"
                                android:alpha="0.55" />

                            <TextView
                                android:id="@+id/tvFatVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="55g / 70g" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbFat"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginBottom="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#EF5350"
                            android:progressBackgroundTint="#33EF5350" />

                        <!-- Carbs row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/result_carbs"
                                android:textSize="11sp"
                                android:alpha="0.55" />

                            <TextView
                                android:id="@+id/tvCarbsVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="180g / 220g" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbCarbs"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginBottom="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#64B5F6"
                            android:progressBackgroundTint="#3364B5F6" />

                        <!-- Net calories -->
                        <TextView
                            android:id="@+id/tvNetCalories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:alpha="0.55"
                            android:gravity="end"
                            android:visibility="gone"
                            tools:text="1,450 kcal net" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step / Activity card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="18dp">

                    <com.example.macromax.StepDonutView
                        android:id="@+id/stepDonut"
                        android:layout_width="110dp"
                        android:layout_height="110dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <!-- Steps row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/main_steps_label"
                                android:textSize="11sp"
                                android:alpha="0.55" />

                            <TextView
                                android:id="@+id/tvStepCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                tools:text="0" />
                        </LinearLayout>

                        <!-- Calories burned row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/main_calories_burned_label"
                                android:textSize="11sp"
                                android:alpha="0.55" />

                            <TextView
                                android:id="@+id/tvCaloriesBurned"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                tools:text="0 kcal" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Water intake card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="12dp">

                    <!-- Title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/water_title"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tvWaterCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="3 / 8" />

                    </LinearLayout>

                    <!-- Progress bar -->
                    <ProgressBar
                        android:id="@+id/pbWater"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#64B5F6"
                        android:progressBackgroundTint="#3364B5F6" />

                    <!-- Controls -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWaterMinus"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="−"
                            android:textSize="18sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            app:cornerRadius="20dp" />

                        <TextView
                            android:id="@+id/tvWaterGlasses"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:textSize="13sp"
                            android:alpha="0.7"
                            tools:text="0 glasses" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWaterPlus"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="+"
                            android:textSize="18sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            app:cornerRadius="20dp" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Workouts card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWorkouts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="6dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="2dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/workout_section_title"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLogWorkout"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="@string/workout_log_btn"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                    </LinearLayout>

                    <!-- Empty state -->
                    <TextView
                        android:id="@+id/tvWorkoutsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/workout_empty"
                        android:textSize="12sp"
                        android:alpha="0.4"
                        android:gravity="center"
                        android:paddingVertical="10dp" />

                    <!-- Programmatic workout rows -->
                    <LinearLayout
                        android:id="@+id/containerWorkouts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Meal Breakdown card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMealBreakdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/meal_breakdown_title"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Breakfast column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingHorizontal="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/meal_short_breakfast"
                                android:textSize="10sp"
                                android:alpha="0.5"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tvMealBfastKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:text="0" />

                            <ProgressBar
                                android:id="@+id/pbMealBfast"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="3dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="?attr/colorPrimary"
                                android:progressBackgroundTint="?attr/colorSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvMealBfastOf"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="9sp"
                                android:alpha="0.45"
                                android:text="—" />

                        </LinearLayout>

                        <!-- Lunch column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingHorizontal="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/meal_short_lunch"
                                android:textSize="10sp"
                                android:alpha="0.5"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tvMealLunchKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:text="0" />

                            <ProgressBar
                                android:id="@+id/pbMealLunch"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="3dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="?attr/colorPrimary"
                                android:progressBackgroundTint="?attr/colorSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvMealLunchOf"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="9sp"
                                android:alpha="0.45"
                                android:text="—" />

                        </LinearLayout>

                        <!-- Dinner column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingHorizontal="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/meal_short_dinner"
                                android:textSize="10sp"
                                android:alpha="0.5"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tvMealDinnerKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:text="0" />

                            <ProgressBar
                                android:id="@+id/pbMealDinner"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="3dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="?attr/colorPrimary"
                                android:progressBackgroundTint="?attr/colorSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvMealDinnerOf"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="9sp"
                                android:alpha="0.45"
                                android:text="—" />

                        </LinearLayout>

                        <!-- Snack column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingHorizontal="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/meal_short_snack"
                                android:textSize="10sp"
                                android:alpha="0.5"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tvMealSnackKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:text="0" />

                            <ProgressBar
                                android:id="@+id/pbMealSnack"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="3dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="?attr/colorPrimary"
                                android:progressBackgroundTint="?attr/colorSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvMealSnackOf"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="9sp"
                                android:alpha="0.45"
                                android:text="—" />

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Today's Food section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_todays_food"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:alpha="0.6"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tvTotalConsumed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:alpha="0.5"
                    tools:text="0 kcal" />
            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvNoFood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_no_food_logged"
                android:textSize="13sp"
                android:alpha="0.45"
                android:gravity="center"
                android:paddingVertical="24dp"
                android:visibility="visible" />

            <!-- Food log list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFoodLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:listitem="@layout/item_food_log" />

            <!-- Bottom spacer so FAB doesn't cover last item -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="88dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB — sits above the bottom nav bar -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="76dp"
        android:src="@drawable/ic_add"
        android:contentDescription="@string/log_food_title" />

    <!-- Bottom navigation bar -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="?attr/colorSurface"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_home" />

        <ImageButton
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_history"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu_history" />

        <ImageButton
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_person"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_profile" />

        <ImageButton
            android:id="@+id/navReports"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_bar_chart"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_reports" />

        <ImageButton
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_settings" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
