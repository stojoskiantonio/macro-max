<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="8dp">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/log_food_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Meal type chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingTop="2dp"
        android:paddingBottom="12dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgMealType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="6dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBreakfast"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meal_breakfast" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLunch"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meal_lunch" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDinner"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meal_dinner" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSnack"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meal_snack" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Search bar + scan button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_search_food"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="?attr/colorOnSurfaceVariant"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:imeOptions="actionSearch"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/btnScanBarcode"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_barcode_scan"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/scan_barcode" />

    </LinearLayout>

    <!-- Tab bar: underline-style -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/toggleTab"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="4dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorHeight="2dp"
        app:tabIndicatorColor="?attr/colorPrimary"
        app:tabTextAppearance="@android:style/TextAppearance.Small"
        app:tabTextColor="#80FFFFFF"
        app:tabSelectedTextColor="?attr/colorOnSurface"
        app:tabRippleColor="@android:color/transparent"
        app:tabBackground="@android:color/transparent">

        <com.google.android.material.tabs.TabItem
            android:id="@+id/btnTabSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_search" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/btnTabFavourites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_favourites" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/btnTabRecipes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_recipes" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/btnTabMyFoods"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_my_foods" />

    </com.google.android.material.tabs.TabLayout>

    <!-- ── SEARCH PANE ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/paneSearch"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Recent foods chips (last 5 quick-add) -->
        <LinearLayout
            android:id="@+id/scrollRecentFoods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_foods_label"
                android:textSize="11sp"
                android:alpha="0.4"
                android:paddingStart="16dp"
                android:layout_marginBottom="4dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgRecentFoods"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:chipSpacingHorizontal="4dp" />

            </HorizontalScrollView>
        </LinearLayout>

        <!-- Content area — states swap via visibility -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Idle hint -->
            <TextView
                android:id="@+id/tvSearchHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/search_food_hint"
                android:gravity="center"
                android:alpha="0.35"
                android:textSize="14sp"
                android:paddingHorizontal="32dp"
                android:visibility="visible" />

            <!-- Loading spinner -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone" />

            <!-- Results list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResults"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />

            <!-- No results / error -->
            <LinearLayout
                android:id="@+id/layoutNoResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvNoResults"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_no_results"
                    android:alpha="0.5"
                    android:textSize="14sp"
                    android:gravity="center" />

            </LinearLayout>

        </FrameLayout>

        <!-- Bottom action: manual entry -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManualEntry"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_add_manually"
            android:alpha="0.6" />

    </LinearLayout>

    <!-- ── RECIPES PANE ────────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/paneRecipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvRecipesEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/recipes_empty"
            android:gravity="center"
            android:alpha="0.4"
            android:textSize="14sp"
            android:paddingHorizontal="32dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecipesLog"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageRecipes"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/recipe_manage"
                android:alpha="0.6" />

        </LinearLayout>

    </FrameLayout>

    <!-- ── MY FOODS PANE ────────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/paneMyFoods"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvMyFoodsEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/my_foods_empty"
            android:gravity="center"
            android:alpha="0.4"
            android:textSize="14sp"
            android:paddingHorizontal="32dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyFoods"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewCustomFood"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/custom_food_new"
                android:alpha="0.6" />

        </LinearLayout>

    </FrameLayout>

    <!-- ── FAVOURITES PANE ──────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/paneFavourites"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvFavEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/favourites_empty"
            android:gravity="center"
            android:alpha="0.4"
            android:textSize="14sp"
            android:paddingHorizontal="32dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFavourites"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

    </FrameLayout>

</LinearLayout>
